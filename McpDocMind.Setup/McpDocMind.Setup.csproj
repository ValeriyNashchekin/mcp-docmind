<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <RootNamespace>McpDocMind.Setup</RootNamespace>
    <AssemblyName>McpDocMind.Setup</AssemblyName>

    <!-- NuGet dotnet tool -->
    <PackAsTool>true</PackAsTool>
    <ToolCommandName>mcp-docmind</ToolCommandName>
    <PackageId>McpDocMind</PackageId>
    <Version>1.0.1</Version>
    <Authors>Valeriy Nashchokin</Authors>
    <Description>Interactive installer for McpDocMind — MCP server for .NET API documentation search. Ingests .NET DLLs, Markdown, Git repos into local SQLite and exposes hybrid search via Model Context Protocol.</Description>
    <PackageTags>mcp;dotnet;api;documentation;revit;autocad;ai;claude;gemini</PackageTags>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <RepositoryUrl>https://github.com/vnashchokin/mcp-docmind</RepositoryUrl>
    <PackageReadmeFile>README.md</PackageReadmeFile>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Spectre.Console" Version="0.50.0" />
  </ItemGroup>

  <ItemGroup>
    <None Include="..\README.md" Pack="true" PackagePath="\" />
  </ItemGroup>

  <!-- Embed McpDocMind.Lite.exe as a resource -->
  <ItemGroup>
    <EmbeddedResource Include="..\McpDocMind.Lite\bin\Release\net10.0\win-x64\publish\McpDocMind.Lite.exe"
                      Condition="Exists('..\McpDocMind.Lite\bin\Release\net10.0\win-x64\publish\McpDocMind.Lite.exe')">
      <LogicalName>McpDocMind.Lite.exe</LogicalName>
    </EmbeddedResource>
  </ItemGroup>

  <!-- Fail fast if Lite wasn't published -->
  <Target Name="ValidateLitePublished" BeforeTargets="PrepareForBuild">
    <Error Condition="!Exists('..\McpDocMind.Lite\bin\Release\net10.0\win-x64\publish\McpDocMind.Lite.exe')"
           Text="McpDocMind.Lite.exe not found. Run: dotnet publish McpDocMind.Lite -c Release -r win-x64 first." />
  </Target>

</Project>
